---
import BaseLayout from "../layouts/BaseLayout.astro";
import ContactForm from "../components/ContactForm.astro";
import { useTranslations } from "../i18n/utils";
import { seoContent } from "../seo/content";
import { buildContactSchemas } from "../seo/schema";

const lang = "en";
const t = useTranslations(lang);
const seo = seoContent[lang];
const schema = buildContactSchemas({
  lang,
  title: seo.metadata.contact.title,
  description: seo.metadata.contact.description,
  homeLabel: t("nav.home"),
  contactLabel: t("nav.contact"),
});
---

<BaseLayout
  title={seo.metadata.contact.title}
  description={seo.metadata.contact.description}
  canonicalPath="/contact/"
  keywords={seo.metadata.contact.keywords}
  schema={schema}
>
  <div class="container container--narrow">
    <header class="page-header">
      <h1>{t("contact.title")}</h1>
      <p>{t("contact.description")}</p>
    </header>

    <ContactForm />

    <aside class="contact-alt">
      <p>{t("contact.alternative")}</p>
      <ul>
        <li>
          <a href="mailto:hello@jesusvillar.dev">hello@jesusvillar.dev</a>
        </li>
        <li>
          <a
            href="https://linkedin.com/in/jesusvillar"
            target="_blank"
            rel="noopener noreferrer">LinkedIn</a
          >
        </li>
        <li>
          <a
            href="https://github.com/jesusvillar"
            target="_blank"
            rel="noopener noreferrer">GitHub</a
          >
        </li>
      </ul>
    </aside>
  </div>
</BaseLayout>
