---
import BaseLayout from "../layouts/BaseLayout.astro";
import ComponentsGalleryPage from "../components/ComponentsGalleryPage.astro";
import { seoContent } from "../seo/content";

const lang = "en";
const seo = seoContent[lang];
---

<BaseLayout
  title={seo.metadata.componentsGallery.title}
  description={seo.metadata.componentsGallery.description}
  canonicalPath="/components-gallery/"
  keywords={seo.metadata.componentsGallery.keywords}
  noindex={true}
>
  <ComponentsGalleryPage lang="en" />
</BaseLayout>
