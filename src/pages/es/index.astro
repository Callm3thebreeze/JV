---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero from "../../components/Hero.astro";
import HomeSeoSection from "../../components/HomeSeoSection.astro";
import { seoContent } from "../../seo/content";
import { buildHomeSchemas } from "../../seo/schema";

const lang = "es";
const seo = seoContent[lang];
const schema = buildHomeSchemas({
  lang,
  title: seo.metadata.home.title,
  description: seo.metadata.home.description,
  featuredProjects: [],
});
---

<BaseLayout
  title={seo.metadata.home.title}
  description={seo.metadata.home.description}
  ogImage="/images/projects/jv-portfolio.png"
  keywords={seo.metadata.home.keywords}
  schema={schema}
>
  <Hero />
  <HomeSeoSection lang={lang} />
</BaseLayout>
