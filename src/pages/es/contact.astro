---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ContactForm from "../../components/ContactForm.astro";
import { useTranslations } from "../../i18n/utils";

const lang = "es";
const t = useTranslations(lang);
---

<BaseLayout
  title={`${t("contact.title")} — Jesús Villar`}
  description={t("contact.description")}
>
  <div class="container container--narrow">
    <header class="page-header">
      <h1>{t("contact.title")}</h1>
      <p>{t("contact.description")}</p>
    </header>

    <ContactForm />

    <aside class="contact-alt">
      <p>{t("contact.alternative")}</p>
      <ul>
        <li>
          <a href="mailto:hello@jesusvillar.dev">hello@jesusvillar.dev</a>
        </li>
        <li>
          <a
            href="https://linkedin.com/in/jesusvillar"
            target="_blank"
            rel="noopener noreferrer">LinkedIn</a
          >
        </li>
        <li>
          <a
            href="https://github.com/jesusvillar"
            target="_blank"
            rel="noopener noreferrer">GitHub</a
          >
        </li>
      </ul>
    </aside>
  </div>
</BaseLayout>
