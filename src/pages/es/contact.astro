---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ContactForm from "../../components/ContactForm.astro";
import { useTranslations } from "../../i18n/utils";

const lang = "es";
const t = useTranslations(lang);
---

<BaseLayout
  title={`${t("contact.title")} — Jesús Villar`}
  description={t("contact.description")}
>
  <div class="container container--narrow">
    <header class="page-header">
      <h1>{t("contact.title")}</h1>
      <p>{t("contact.description")}</p>
    </header>

    <ContactForm />

    <aside class="contact-alt">
      <p>{t("contact.alternative")}</p>
      <ul>
        <li>
          <a href="mailto:hello@jesusvillar.dev">hello@jesusvillar.dev</a>
        </li>
        <li>
          <a
            href="https://linkedin.com/in/jesusvillar"
            target="_blank"
            rel="noopener noreferrer">LinkedIn</a
          >
        </li>
        <li>
          <a
            href="https://github.com/jesusvillar"
            target="_blank"
            rel="noopener noreferrer">GitHub</a
          >
        </li>
      </ul>
    </aside>
  </div>
</BaseLayout>

<style>
  .page-header {
    margin-bottom: var(--space-xl);
  }

  .page-header p {
    color: var(--color-text-muted);
    margin-top: var(--space-sm);
  }

  .contact-alt {
    margin-top: var(--space-2xl);
    padding-top: var(--space-xl);
    border-top: 1px solid var(--color-border);
  }

  .contact-alt p {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    margin-bottom: var(--space-md);
  }

  .contact-alt ul {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-lg);
  }

  .contact-alt a {
    font-weight: 500;
  }
</style>
