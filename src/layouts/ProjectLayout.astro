---
import BaseLayout from "./BaseLayout.astro";
import { Image } from "astro:assets";
import ProjectDetailBlock from "../components/ProjectDetailBlock.astro";
import { getLangFromUrl, useTranslations, localizedPath } from "../i18n/utils";
import type { CollectionEntry } from "astro:content";
import { resolveProjectThumbnail } from "../utils/projectThumbnail";
import { formatInlineRichText } from "../utils/formatRichText";

interface Props {
  project: CollectionEntry<"projects">;
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const { project } = Astro.props;
const {
  title,
  description,
  date,
  thumbnail,
  logo,
  intro,
  overview,
  sections,
  techStack,
  links,
} = project.data;
const resolvedLogo = resolveProjectThumbnail(logo?.src ?? thumbnail?.src);
const logoAlt = logo?.alt ?? thumbnail?.alt;

const formattedDate = date.toLocaleDateString(
  lang === "es" ? "es-ES" : "en-US",
  {
    year: "numeric",
    month: "long",
  },
);
const introHtml = formatInlineRichText(intro ?? description);
const overviewHtml = overview ? formatInlineRichText(overview) : null;
---

<BaseLayout title={`${title} — Jesús Villar`} description={description}>
  <article class="container container--narrow">
    <nav class="project-nav">
      <a href={localizedPath(lang, "/projects/")}>&larr; {t("project.back")}</a>
    </nav>

    <header class="project-header">
      <div class="project-title-row">
        <div>
          <h1 class="title--inter">{title}</h1>
          <p class="project-date">{formattedDate}</p>
        </div>
        {
          resolvedLogo && (
            <Image
              class="project-logo"
              src={resolvedLogo}
              alt={logoAlt}
              loading="eager"
              format="webp"
              widths={[220, 320, 440]}
              sizes="(max-width: 820px) 120px, 180px"
            />
          )
        }
      </div>
    </header>

    <section class="project-content project-intro-block">
      <p set:html={introHtml} />
      {overviewHtml && <p set:html={overviewHtml} />}
    </section>

    {
      sections.map((section) => (
        <ProjectDetailBlock
          title={section.title}
          text={section.text}
          image={section.image}
          imagePosition={section.imagePosition}
        />
      ))
    }

    {
      techStack.length > 0 && (
        <section class="project-tech">
          <h2 class="title--inter">{t("project.techStack")}</h2>
          <ul class="tech-list">
            {techStack.map((tech) => (
              <li>{tech}</li>
            ))}
          </ul>
        </section>
      )
    }

    {
      (links.live || links.repo || links.figma) && (
        <section class="project-links">
          {links.live && (
            <a href={links.live} target="_blank" rel="noopener noreferrer">
              {t("project.links.live")} &rarr;
            </a>
          )}
          {links.repo && (
            <a href={links.repo} target="_blank" rel="noopener noreferrer">
              {t("project.links.repo")} &rarr;
            </a>
          )}
          {links.figma && (
            <a href={links.figma} target="_blank" rel="noopener noreferrer">
              {t("project.links.figma")} &rarr;
            </a>
          )}
        </section>
      )
    }
  </article>
</BaseLayout>

<style>
  .project-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-xl);
  }

  .project-header {
    margin-bottom: var(--space-xl);
  }

  .project-title-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-lg);
  }

  .project-date {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
  }

  .project-logo {
    width: clamp(96px, 18vw, 180px);
    height: auto;
    border-radius: var(--radius-sm);
    border: none !important;
    outline: none !important;
    box-shadow: none !important;
    background: transparent;
    object-fit: contain;
  }

  .project-content {
    margin-bottom: var(--space-2xl);
    line-height: 1.8;
  }

  .project-intro-block {
    margin-top: var(--space-md);
  }

  .project-intro-block p {
    margin-bottom: var(--space-md);
  }

  .project-tech {
    margin-bottom: var(--space-xl);
  }

  .project-tech h2 {
    font-size: var(--text-xl);
    margin-bottom: var(--space-md);
  }

  .tech-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .tech-list li {
    background-color: var(--color-border);
    padding: var(--space-xs) var(--space-md);
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
  }

  .project-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-lg);
    padding-top: var(--space-xl);
    border-top: 1px solid var(--color-border);
  }

  .project-links a {
    font-weight: 600;
  }

  @media (max-width: 820px) {
    .project-title-row {
      align-items: center;
    }

    .project-logo {
      width: clamp(84px, 24vw, 140px);
    }
  }
</style>
