---
import BaseLayout from "./BaseLayout.astro";
import { Image } from "astro:assets";
import Pill from "../components/Pill.astro";
import ProjectDetailBlock from "../components/ProjectDetailBlock.astro";
import {
  getLangFromUrl,
  useTranslations,
  localizedPath,
  getProjectTranslation,
  getProjectSlug,
} from "../i18n/utils";
import type { CollectionEntry } from "astro:content";
import { resolveProjectThumbnail } from "../utils/projectThumbnail";
import { formatInlineRichText } from "../utils/formatRichText";
import { buildProjectKeywords, buildProjectSchemas } from "../seo/schema";

interface Props {
  project: CollectionEntry<"projects">;
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const { project } = Astro.props;
const {
  title,
  description,
  date,
  logo,
  role,
  intro,
  overview,
  sections,
  techStack,
  links,
} = project.data;
const resolvedLogo = logo?.src ? resolveProjectThumbnail(logo.src) : null;
const logoAlt = logo?.alt ?? "";
const slug = getProjectSlug(project.id);
const otherLang = lang === "es" ? "en" : "es";
const translatedProject = await getProjectTranslation(
  project.data.translationId,
  otherLang,
);
const translatedProjectPath = translatedProject
  ? localizedPath(otherLang, `/projects/${getProjectSlug(translatedProject.id)}/`)
  : null;
const seoTitle =
  lang === "es"
    ? `${title} | Caso de estudio web | Jesús Villar`
    : `${title} | Web Design & Frontend Case Study | Jesús Villar`;
const seoKeywords = buildProjectKeywords(project, lang);
const seoSchema = buildProjectSchemas({
  lang,
  project,
  title: seoTitle,
  description,
  homeLabel: t("nav.home"),
  projectsLabel: t("nav.projects"),
});
const socialImage = `/images/projects/${slug}.png`;

const formattedDate = date.toLocaleDateString(
  lang === "es" ? "es-ES" : "en-US",
  {
    year: "numeric",
    month: "long",
  },
);
const introHtml = formatInlineRichText(intro ?? description);
const overviewHtml = overview ? formatInlineRichText(overview) : null;
const roleLabel = lang === "es" ? "Rol" : "Role";
---

<BaseLayout
  title={seoTitle}
  description={description}
  canonicalPath={localizedPath(lang, `/projects/${slug}/`)}
  ogImage={socialImage}
  keywords={seoKeywords}
  pageType="article"
  publishedTime={date.toISOString()}
  modifiedTime={date.toISOString()}
  schema={seoSchema}
>
  <article class="container container--narrow">
    <nav class="project-nav">
      <a href={localizedPath(lang, "/projects/")}>&larr; {t("project.back")}</a>
      {
        translatedProjectPath && (
          <a href={translatedProjectPath}>{t("project.otherLang")} &rarr;</a>
        )
      }
    </nav>

    <header class="project-header">
      <div class="project-title-row">
        <div>
          <h1 class="title--inter">{title}</h1>
          {
            role && (
              <p class="project-role">
                {roleLabel}: {role}
              </p>
            )
          }
          <p class="project-date">{formattedDate}</p>
        </div>
        {
          resolvedLogo && (
            <Image
              class="project-logo"
              src={resolvedLogo}
              alt={logoAlt}
              loading="eager"
              format="webp"
              widths={[220, 320, 440]}
              sizes="(max-width: 820px) 120px, 180px"
            />
          )
        }
      </div>
    </header>

    <section class="project-content project-intro-block">
      <p set:html={introHtml} />
      {overviewHtml && <p set:html={overviewHtml} />}
    </section>

    {
      sections.map((section) => (
        <ProjectDetailBlock
          title={section.title}
          text={section.text}
          image={section.image}
          imagePosition={section.imagePosition}
        />
      ))
    }

    {
      techStack.length > 0 && (
        <section class="project-tech">
          <h2 class="title--inter-700">{t("project.techStack")}</h2>
          <div class="tech-pills">
            {techStack.map((tech) => (
              <Pill variant="primary" size="sm">
                {tech}
              </Pill>
            ))}
          </div>
        </section>
      )
    }

    {
      (links.live || links.repo || links.figma) && (
        <section class="project-links">
          {links.live && (
            <a href={links.live} target="_blank" rel="noopener noreferrer">
              {t("project.links.live")} &rarr;
            </a>
          )}
          {links.repo && (
            <a href={links.repo} target="_blank" rel="noopener noreferrer">
              {t("project.links.repo")} &rarr;
            </a>
          )}
          {links.figma && (
            <a href={links.figma} target="_blank" rel="noopener noreferrer">
              {t("project.links.figma")} &rarr;
            </a>
          )}
        </section>
      )
    }
  </article>
</BaseLayout>

<style>
  .project-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-xl);
  }

  .project-header {
    margin-bottom: var(--space-xl);
  }

  .project-title-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-lg);
  }

  .project-date {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
  }

  .project-role {
    margin-top: var(--space-xs);
    margin-bottom: var(--space-xs);
    font-size: var(--text-base);
    font-family: var(--font-body);
    font-weight: 500;
    color: var(--color-text);
  }

  .project-logo {
    width: 15rem;
    max-width: 100%;
    height: auto;
    border-radius: var(--radius-sm);
    border: none !important;
    outline: none !important;
    box-shadow: none !important;
    background: transparent;
    object-fit: contain;
  }

  .project-content {
    margin-bottom: var(--space-2xl);
    line-height: 1.8;
  }

  .project-intro-block {
    margin-top: var(--space-md);
  }

  .project-intro-block p {
    margin-bottom: var(--space-md);
  }

  .project-tech {
    margin-bottom: var(--space-xl);
  }

  .project-tech h2 {
    font-size: var(--text-xl);
    margin-bottom: var(--space-md);
  }

  .tech-pills {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
  }

  .project-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-lg);
    padding-top: var(--space-xl);
    border-top: 1px solid var(--color-border);
  }

  .project-links a {
    font-weight: 600;
  }

  @media (min-width: 1025px) {
    .project-content {
      margin-bottom: 8rem;
    }
  }

  @media (max-width: 820px) {
    .project-title-row {
      align-items: center;
    }
  }
</style>
