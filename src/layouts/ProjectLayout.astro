---
import BaseLayout from "./BaseLayout.astro";
import {
  getLangFromUrl,
  useTranslations,
  localizedPath,
  getProjectTranslation,
  getProjectSlug,
} from "../i18n/utils";
import type { CollectionEntry } from "astro:content";

interface Props {
  project: CollectionEntry<"projects">;
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const { project } = Astro.props;
const {
  title,
  description,
  tags,
  date,
  thumbnail,
  techStack,
  links,
  translationId,
} = project.data;

const targetLang = lang === "en" ? "es" : "en";
const translation = await getProjectTranslation(translationId, targetLang);
const translationSlug = translation ? getProjectSlug(translation.id) : null;

const formattedDate = date.toLocaleDateString(
  lang === "es" ? "es-ES" : "en-US",
  {
    year: "numeric",
    month: "long",
  },
);
---

<BaseLayout title={`${title} — Jesús Villar`} description={description}>
  <article class="container container--narrow">
    <nav class="project-nav">
      <a href={localizedPath(lang, "/projects/")}>&larr; {t("project.back")}</a>
      {
        translationSlug && (
          <a href={localizedPath(targetLang, `/projects/${translationSlug}/`)}>
            {t("project.otherLang")}
          </a>
        )
      }
    </nav>

    <header class="project-header">
      <div class="project-tags">
        {
          tags.map((tag) => (
            <span class={`tag tag--${tag}`}>{t(`projects.tag.${tag}`)}</span>
          ))
        }
      </div>
      <h1>{title}</h1>
      <p class="project-date">{formattedDate}</p>
    </header>

    {
      thumbnail && (
        <img
          class="project-thumbnail"
          src={thumbnail.src}
          alt={thumbnail.alt}
          loading="eager"
        />
      )
    }

    <div class="project-content">
      <slot />
    </div>

    {
      techStack.length > 0 && (
        <section class="project-tech">
          <h2>{t("project.techStack")}</h2>
          <ul class="tech-list">
            {techStack.map((tech) => (
              <li>{tech}</li>
            ))}
          </ul>
        </section>
      )
    }

    {
      (links.live || links.repo || links.figma) && (
        <section class="project-links">
          {links.live && (
            <a href={links.live} target="_blank" rel="noopener noreferrer">
              {t("project.links.live")} &rarr;
            </a>
          )}
          {links.repo && (
            <a href={links.repo} target="_blank" rel="noopener noreferrer">
              {t("project.links.repo")} &rarr;
            </a>
          )}
          {links.figma && (
            <a href={links.figma} target="_blank" rel="noopener noreferrer">
              {t("project.links.figma")} &rarr;
            </a>
          )}
        </section>
      )
    }
  </article>
</BaseLayout>

<style>
  .project-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-xl);
  }

  .project-header {
    margin-bottom: var(--space-xl);
  }

  .project-tags {
    display: flex;
    gap: var(--space-sm);
    margin-bottom: var(--space-md);
  }

  .tag {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: var(--space-xs) var(--space-sm);
    border-radius: var(--radius-full);
  }

  .tag--design {
    background-color: color-mix(
      in srgb,
      var(--color-tag-design) 20%,
      transparent
    );
    color: var(--color-tag-design);
  }

  .tag--development {
    background-color: color-mix(
      in srgb,
      var(--color-tag-development) 20%,
      transparent
    );
    color: var(--color-tag-development);
  }

  .project-date {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
  }

  .project-thumbnail {
    width: 100%;
    border-radius: var(--radius-lg);
    margin-bottom: var(--space-xl);
  }

  .project-content {
    margin-bottom: var(--space-2xl);
    line-height: 1.8;
  }

  .project-content :global(h2) {
    margin-top: var(--space-xl);
    margin-bottom: var(--space-md);
  }

  .project-content :global(p) {
    margin-bottom: var(--space-md);
  }

  .project-content :global(img) {
    border-radius: var(--radius-md);
    margin-block: var(--space-lg);
  }

  .project-tech {
    margin-bottom: var(--space-xl);
  }

  .project-tech h2 {
    font-size: var(--text-xl);
    margin-bottom: var(--space-md);
  }

  .tech-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .tech-list li {
    background-color: var(--color-border);
    padding: var(--space-xs) var(--space-md);
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
  }

  .project-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-lg);
    padding-top: var(--space-xl);
    border-top: 1px solid var(--color-border);
  }

  .project-links a {
    font-weight: 600;
  }
</style>
