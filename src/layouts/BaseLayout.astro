---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import SEO from "../components/SEO.astro";
import { getLangFromUrl, isHomePath } from "../i18n/utils";
import mainLogo from "../assets/main-logo.png";
import smallLogo from "../assets/small-logo.png";
import type { Lang } from "../i18n/ui";
import type { JsonLd } from "../seo/schema";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonicalPath?: string;
  keywords?: string[];
  pageType?: "website" | "article";
  noindex?: boolean;
  publishedTime?: string;
  modifiedTime?: string;
  schema?: JsonLd[];
  alternates?: Partial<Record<Lang, string>> | false;
}

const lang = getLangFromUrl(Astro.url);
const isHome = isHomePath(Astro.url.pathname);
const {
  title,
  description,
  ogImage,
  canonicalPath,
  keywords,
  pageType,
  noindex,
  publishedTime,
  modifiedTime,
  schema,
  alternates,
} = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/png" href="/favicon.png" />

    <!-- Google Fonts: avoid visible font swap on reload -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bagel+Fat+One&family=Inter:wght@400;700;900&display=block"
      rel="stylesheet"
    />

    {
      isHome ? (
        <link rel="preload" as="image" href={mainLogo.src} />
      ) : (
        <link rel="preload" as="image" href={smallLogo.src} />
      )
    }

    <SEO
      title={title}
      description={description}
      lang={lang}
      ogImage={ogImage}
      canonicalPath={canonicalPath}
      keywords={keywords}
      pageType={pageType}
      noindex={noindex}
      publishedTime={publishedTime}
      modifiedTime={modifiedTime}
      schema={schema}
      alternates={alternates}
    />

    <ClientRouter fallback="animate" />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
