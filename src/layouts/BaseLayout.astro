---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import SEO from "../components/SEO.astro";
import { getLangFromUrl } from "../i18n/utils";
import mainLogo from "../assets/main-logo.png";
import smallLogo from "../assets/small-logo.png";
import altLogo from "../assets/alt-logo.png";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonicalPath?: string;
}

const lang = getLangFromUrl(Astro.url);
const { title, description, ogImage, canonicalPath } = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/png" href="/favicon.png" />

    <!-- Google Fonts: avoid visible font swap on reload -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bagel+Fat+One&family=Inter:wght@400;700;900&display=block"
      rel="stylesheet"
    />

    <link rel="preload" as="image" href={mainLogo.src} />
    <link rel="preload" as="image" href={smallLogo.src} />
    <link rel="preload" as="image" href={altLogo.src} />

    <SEO
      title={title}
      description={description}
      lang={lang}
      ogImage={ogImage}
      canonicalPath={canonicalPath}
    />

    <ClientRouter fallback="animate" />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
