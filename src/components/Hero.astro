---
import { getLangFromUrl, useTranslations } from "../i18n/utils";
import Button from "./Button.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="hero">
  <div class="container">
    <h1 class="hero-headline">{t("home.hero.headline")}</h1>
    <p class="hero-subline">{t("home.hero.subline")}</p>
    <div class="hero-cta">
      <Button
        href={lang === "en" ? "/projects/" : "/es/projects/"}
        variant="primary"
        size="lg"
        iconPosition="right"
      >
        {t("home.hero.cta.projects")}
        <svg
          slot="icon"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M5 12h14"></path>
          <path d="m12 5 7 7-7 7"></path>
        </svg>
      </Button>
      <Button
        href={lang === "en" ? "/contact/" : "/es/contact/"}
        variant="secondary"
        size="lg"
        iconPosition="left"
      >
        {t("home.hero.cta.contact")}
        <svg
          slot="icon"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.25"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <rect x="3" y="5" width="18" height="14" rx="2"></rect>
          <path d="m4 7 8 6 8-6"></path>
        </svg>
      </Button>
    </div>
  </div>
</section>

<style>
  .hero {
    padding-block: var(--space-3xl);
    text-align: center;
  }

  .hero-headline {
    max-width: 14ch;
    margin-inline: auto;
    margin-bottom: var(--space-lg);
  }

  .hero-subline {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    max-width: 50ch;
    margin-inline: auto;
    margin-bottom: var(--space-xl);
  }

  .hero-cta {
    display: flex;
    gap: var(--space-md);
    justify-content: center;
    flex-wrap: wrap;
  }
</style>
