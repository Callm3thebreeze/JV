---
import { getLangFromUrl, useTranslations } from "../i18n/utils";
import FilterPills from "./FilterPills.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const filters = [
  { key: "all", label: t("projects.filter.all") },
  { key: "design", label: t("projects.filter.design") },
  { key: "development", label: t("projects.filter.development") },
];
---

<div class="tag-filter" role="group" aria-label="Filter projects">
  <FilterPills
    items={filters.map((filter) => ({
      value: filter.key,
      label: filter.label,
    }))}
    defaultValue="all"
    multiple={false}
    variant="primary"
    size="sm"
    ariaLabel="Filter projects"
    class="tag-filter__pills"
  />
</div>

<script>
  const setupTagFilter = () => {
    const groups = document.querySelectorAll<HTMLElement>(".tag-filter__pills");
    const cards = document.querySelectorAll<HTMLElement>(".project-card");

    groups.forEach((group) => {
      if (group.dataset.tagFilterInitialized === "true") return;

      group.addEventListener("filterpillschange", (event) => {
        const detail = (event as CustomEvent<{ values: string[] }>).detail;
        const activeFilter = detail?.values?.[0] ?? "all";

        cards.forEach((card) => {
          const tags = card.dataset.tags?.split(",") ?? [];
          if (activeFilter === "all" || tags.includes(activeFilter)) {
            card.style.display = "";
          } else {
            card.style.display = "none";
          }
        });
      });

      group.dataset.tagFilterInitialized = "true";
    });
  };

  setupTagFilter();
  document.addEventListener("astro:page-load", setupTagFilter);
</script>

<style>
  .tag-filter {
    margin-bottom: var(--space-xl);
  }

  .tag-filter :global(.filter-pills) {
    gap: var(--space-sm);
  }

  .tag-filter
    :global(
      .tag-filter__pills.filter-pills--primary .filter-pill.is-active,
      .tag-filter__pills.filter-pills--primary .filter-pill[aria-pressed="true"]
    ) {
    background-color: var(--color-blue-light);
    color: #fff;
  }
</style>
