---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import { formatInlineRichText } from "../utils/formatRichText";

interface BlockImage {
  src: ImageMetadata;
  alt: string;
}

interface Props {
  title: string;
  text: string;
  image?: BlockImage;
  imagePosition?: "left" | "right" | "full";
}

const { title, text, image, imagePosition = "right" } = Astro.props;
const textParagraphs = text
  .split(/\n\s*\n/g)
  .map((paragraph) => paragraph.trim())
  .filter(Boolean);
const textParagraphsHtml = textParagraphs.map((paragraph) =>
  formatInlineRichText(paragraph),
);
---

<section
  class:list={[
    "project-detail-block",
    `project-detail-block--${imagePosition}`,
  ]}
>
  {
    image && imagePosition === "left" && (
      <Image
        class="project-detail-block__image"
        src={image.src}
        alt={image.alt}
        format="webp"
        widths={[480, 720, 960]}
        sizes="(max-width: 820px) 100vw, 380px"
        loading="lazy"
      />
    )
  }

  <div class="project-detail-block__content">
    <h2 class="title--inter">{title}</h2>
    {textParagraphsHtml.map((paragraphHtml) => <p set:html={paragraphHtml} />)}
  </div>

  {
    image && imagePosition === "right" && (
      <Image
        class="project-detail-block__image"
        src={image.src}
        alt={image.alt}
        format="webp"
        widths={[480, 720, 960]}
        sizes="(max-width: 820px) 100vw, 380px"
        loading="lazy"
      />
    )
  }

  {
    image && imagePosition === "full" && (
      <Image
        class="project-detail-block__image project-detail-block__image--full"
        src={image.src}
        alt={image.alt}
        format="webp"
        widths={[720, 960, 1280]}
        sizes="(max-width: 820px) 100vw, 800px"
        loading="lazy"
      />
    )
  }
</section>

<style>
  .project-detail-block {
    display: grid;
    gap: var(--space-lg);
    margin-bottom: var(--space-2xl);
    align-items: start;
  }

  .project-detail-block--left,
  .project-detail-block--right {
    grid-template-columns: minmax(0, 1fr) minmax(240px, 36%);
  }

  .project-detail-block--left {
    grid-template-columns: minmax(240px, 36%) minmax(0, 1fr);
  }

  .project-detail-block--full {
    grid-template-columns: 1fr;
  }

  .project-detail-block__content h2 {
    margin-bottom: var(--space-md);
  }

  .project-detail-block__content p {
    margin-bottom: var(--space-md);
    line-height: 1.75;
  }

  .project-detail-block__image {
    width: 100%;
    border-radius: var(--radius-sm);
    border: none !important;
    outline: none !important;
    box-shadow: none !important;
    background: transparent;
  }

  .project-detail-block__image--full {
    grid-column: 1 / -1;
  }

  @media (max-width: 820px) {
    .project-detail-block--left,
    .project-detail-block--right {
      grid-template-columns: 1fr;
    }
  }
</style>
