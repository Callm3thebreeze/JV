---
import { getLangFromUrl, useTranslations, localizedPath } from "../i18n/utils";
import LanguageSwitcher from "./LanguageSwitcher.astro";
import smallLogo from "../assets/small-logo.png";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const isHome = Astro.url.pathname === "/" || Astro.url.pathname === "/es/";
---

<header class="site-header" data-site-header>
  <div
    class:list={["container header-inner", { "header-inner--home": isHome }]}
  >
    {
      !isHome && (
        <a
          href={localizedPath(lang, "/")}
          class="logo"
          aria-label={t("nav.home")}
        >
          <img
            src={smallLogo.src}
            width={smallLogo.width}
            height={smallLogo.height}
            alt="Jesús Villar"
            class="logo__img"
            loading="eager"
            decoding="async"
          />
        </a>
      )
    }

    <nav class="main-nav" aria-label="Main navigation">
      <ul>
        <li><a href={localizedPath(lang, "/")}>{t("nav.home")}</a></li>
        <li>
          <a href={localizedPath(lang, "/projects/")}>{t("nav.projects")}</a>
        </li>
        <li>
          <a href={localizedPath(lang, "/contact/")}>{t("nav.contact")}</a>
        </li>
      </ul>
    </nav>

    <div class="header-lang-switcher">
      <LanguageSwitcher />
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    height: var(--header-height);
    background-color: transparent;
    border-bottom: 5px solid transparent;
    transition:
      transform var(--transition-base),
      background-color var(--transition-base),
      border-color var(--transition-base);
    will-change: transform;
  }

  .site-header.is-hidden {
    transform: translateY(calc(-100% - var(--space-sm)));
  }

  .site-header.is-scrolled {
    background-color: rgb(255, 245, 210);
    border-bottom-color: var(--color-navy);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
  }

  .header-inner--home {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    justify-content: unset;
  }

  .header-inner--home .main-nav {
    grid-column: 2;
    justify-self: center;
  }

  .header-inner--home .header-lang-switcher {
    grid-column: 3;
    justify-self: end;
  }

  .header-lang-switcher {
    display: flex;
    justify-content: flex-end;
  }

  .logo {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
  }

  .logo__img {
    width: clamp(3rem, 7vw, 5.5rem);
    height: auto;
    transition:
      transform var(--transition-fast),
      filter var(--transition-fast);
  }

  .logo:hover .logo__img {
    transform: translateY(-1px);
    filter: saturate(1.1);
  }

  .logo:focus-visible {
    outline: var(--border-medium) solid var(--color-blue-light);
    outline-offset: 4px;
    border-radius: var(--radius-md);
  }

  .main-nav ul {
    display: flex;
    gap: var(--space-lg);
  }

  .main-nav a {
    color: var(--color-text);
    font-size: var(--text-sm);
    font-weight: 500;
    transition: color var(--transition-fast);
  }

  .main-nav a:hover {
    color: var(--color-accent);
  }

  @media (max-width: 640px) {
    .header-inner {
      gap: var(--space-md);
    }

    .header-inner--home {
      grid-template-columns: 1fr auto;
      gap: var(--space-md);
    }

    .header-inner--home .main-nav {
      grid-column: 1;
      justify-self: start;
    }

    .header-inner--home .header-lang-switcher {
      grid-column: 2;
      justify-self: end;
    }

    .main-nav ul {
      gap: var(--space-md);
    }
  }
</style>

<script is:inline>
  const setupHeaderScroll = () => {
    const header = document.querySelector("[data-site-header]");
    if (!(header instanceof HTMLElement)) return;

    if (window.__jvHeaderScrollCleanup__) {
      window.__jvHeaderScrollCleanup__();
    }

    let lastScrollY = window.scrollY;
    let ticking = false;

    const updateHeaderVisibility = () => {
      const currentScrollY = window.scrollY;
      const delta = currentScrollY - lastScrollY;
      const isAtTop = currentScrollY <= 16;

      if (isAtTop || delta < -4) {
        header.classList.remove("is-hidden");
      } else if (delta > 4) {
        header.classList.add("is-hidden");
      }

      header.classList.toggle("is-scrolled", !isAtTop);

      lastScrollY = currentScrollY;
      ticking = false;
    };

    const onScroll = () => {
      if (ticking) return;
      ticking = true;
      window.requestAnimationFrame(updateHeaderVisibility);
    };

    window.addEventListener("scroll", onScroll, { passive: true });
    window.__jvHeaderScrollCleanup__ = () => {
      window.removeEventListener("scroll", onScroll);
    };

    updateHeaderVisibility();
  };

  setupHeaderScroll();
  document.addEventListener("astro:page-load", setupHeaderScroll);
</script>
