---
import { existsSync } from "node:fs";
import type { CollectionEntry } from "astro:content";
import Card from "./Card.astro";
import {
  getLangFromUrl,
  useTranslations,
  localizedPath,
  getProjectSlug,
} from "../i18n/utils";

interface Props {
  project: CollectionEntry<"projects">;
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const { project } = Astro.props;
const { title, description, tags, date, thumbnail } = project.data;
const slug = getProjectSlug(project.id);
const thumbnailExists = thumbnail?.src
  ? existsSync(new URL(`../../public${thumbnail.src}`, import.meta.url))
  : false;
const useFallbackMedia = !thumbnail?.src || !thumbnailExists;

const cardVariant = tags.includes("design")
  ? "red"
  : tags.includes("development")
    ? "green"
    : "blue";

const formattedDate = date.toLocaleDateString(
  lang === "es" ? "es-ES" : "en-US",
  {
    year: "numeric",
    month: "short",
  },
);
---

<a
  href={localizedPath(lang, `/projects/${slug}/`)}
  class="project-card"
  data-tags={tags.join(",")}
>
  <Card
    variant={cardVariant}
    class="project-card__frame"
    useDefaultMedia={useFallbackMedia}
    defaultMediaAlt="Jesús Villar alt logo"
  >
    {
      thumbnail?.src && thumbnailExists && (
        <img
          slot="media"
          class="card-thumbnail"
          src={thumbnail.src}
          alt={thumbnail.alt}
          loading="lazy"
        />
      )
    }

    <div class="card-tags">
      {
        tags.map((tag) => (
          <span class={`tag tag--${tag}`}>{t(`projects.tag.${tag}`)}</span>
        ))
      }
    </div>
    <h3 class="card-title">{title}</h3>
    <p class="card-description">{description}</p>
    <time class="card-date" datetime={date.toISOString()}>{formattedDate}</time>
  </Card>
</a>

<style>
  .project-card {
    display: block;
    color: var(--color-text);
    transition:
      transform var(--transition-base),
      color var(--transition-base);
  }

  .project-card:hover {
    transform: translateY(-2px);
    color: var(--color-text);
  }

  .project-card__frame {
    height: 100%;
  }

  .card-thumbnail {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    margin-bottom: var(--space-sm);
  }

  .tag {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 2px var(--space-sm);
    border-radius: var(--radius-full);
  }

  .tag--design {
    background-color: color-mix(in srgb, var(--color-red) 16%, transparent);
    color: var(--color-red);
    border-color: var(--color-red);
  }

  .tag--development {
    background-color: color-mix(in srgb, var(--color-green) 16%, transparent);
    color: var(--color-green);
    border-color: var(--color-green);
  }

  .card-title {
    margin: 0 0 var(--space-sm);
    font-family: var(--font-body);
    font-size: clamp(1.7rem, 1.45rem + 0.8vw, 2.2rem);
    font-weight: 700;
    line-height: 0.95;
    letter-spacing: -0.05em;
    color: var(--color-navy);
  }

  .card-description {
    margin: 0;
    font-size: var(--text-base);
    color: var(--color-navy);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-date {
    display: inline-block;
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    margin-top: var(--space-md);
  }
</style>
