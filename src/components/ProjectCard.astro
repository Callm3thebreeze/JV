---
import type { CollectionEntry } from "astro:content";
import {
  getLangFromUrl,
  useTranslations,
  localizedPath,
  getProjectSlug,
} from "../i18n/utils";

interface Props {
  project: CollectionEntry<"projects">;
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const { project } = Astro.props;
const { title, description, tags, date, thumbnail } = project.data;
const slug = getProjectSlug(project.id);

const formattedDate = date.toLocaleDateString(
  lang === "es" ? "es-ES" : "en-US",
  {
    year: "numeric",
    month: "short",
  },
);
---

<a
  href={localizedPath(lang, `/projects/${slug}/`)}
  class="project-card"
  data-tags={tags.join(",")}
>
  {
    thumbnail && (
      <img
        class="card-thumbnail"
        src={thumbnail.src}
        alt={thumbnail.alt}
        loading="lazy"
      />
    )
  }
  <div class="card-body">
    <div class="card-tags">
      {
        tags.map((tag) => (
          <span class={`tag tag--${tag}`}>{t(`projects.tag.${tag}`)}</span>
        ))
      }
    </div>
    <h3 class="card-title">{title}</h3>
    <p class="card-description">{description}</p>
    <time class="card-date" datetime={date.toISOString()}>{formattedDate}</time>
  </div>
</a>

<style>
  .project-card {
    display: flex;
    flex-direction: column;
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    overflow: hidden;
    transition: all var(--transition-base);
    color: var(--color-text);
  }

  .project-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-2px);
    color: var(--color-text);
  }

  .card-thumbnail {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
  }

  .card-body {
    padding: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .card-tags {
    display: flex;
    gap: var(--space-xs);
  }

  .tag {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 2px var(--space-sm);
    border-radius: var(--radius-full);
  }

  .tag--design {
    background-color: color-mix(
      in srgb,
      var(--color-tag-design) 20%,
      transparent
    );
    color: var(--color-tag-design);
  }

  .tag--development {
    background-color: color-mix(
      in srgb,
      var(--color-tag-development) 20%,
      transparent
    );
    color: var(--color-tag-development);
  }

  .card-title {
    font-size: var(--text-lg);
  }

  .card-description {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-date {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    margin-top: auto;
  }
</style>
