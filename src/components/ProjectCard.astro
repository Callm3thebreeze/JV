---
import { existsSync } from "node:fs";
import type { CollectionEntry } from "astro:content";
import Card from "./Card.astro";
import Pill from "./Pill.astro";
import {
  getLangFromUrl,
  useTranslations,
  localizedPath,
  getProjectSlug,
} from "../i18n/utils";

interface Props {
  project: CollectionEntry<"projects">;
  showDescription?: boolean;
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const { project, showDescription = false } = Astro.props;
const { title, description, tags, date, dateLabel, thumbnail } = project.data;
const slug = getProjectSlug(project.id);
const useAltLogoForCard = slug === "jv-portfolio";
const thumbnailExists = thumbnail?.src
  ? existsSync(new URL(`../../public${thumbnail.src}`, import.meta.url))
  : false;
const useFallbackMedia =
  useAltLogoForCard || !thumbnail?.src || !thumbnailExists;

const cardVariant = "blue";

const formattedDate = date.toLocaleDateString(
  lang === "es" ? "es-ES" : "en-US",
  {
    year: "numeric",
    month: "short",
  },
);
const cardDateLabel = dateLabel ?? formattedDate;

const tagVariantMap = {
  design: "primary",
  development: "success",
} as const;
---

<a
  href={localizedPath(lang, `/projects/${slug}/`)}
  class="project-card"
  aria-label={title}
  data-tags={tags.join(",")}
>
  <Card
    variant={cardVariant}
    class="project-card__frame"
    useDefaultMedia={useFallbackMedia}
    defaultMediaAlt="Jesús Villar alt logo"
  >
    {
      !useAltLogoForCard && thumbnail?.src && thumbnailExists && (
        <img
          slot="media"
          class="card-thumbnail"
          src={thumbnail.src}
          alt={thumbnail.alt}
          loading="lazy"
        />
      )
    }
    {showDescription && <p class="card-description">{description}</p>}
    <div class="card-meta">
      <div class="card-tags">
        {
          tags.map((tag) => (
            <Pill variant={tagVariantMap[tag]} size="sm">
              {t(`projects.tag.${tag}`)}
            </Pill>
          ))
        }
      </div>
      <time class="card-date" datetime={date.toISOString()}
        >{cardDateLabel}</time
      >
    </div>
  </Card>
</a>

<style>
  .project-card {
    display: block;
    color: var(--color-text);
    text-decoration: none;
    font-weight: inherit;
    transform-origin: 50% 50%;
    transition:
      transform var(--transition-base),
      color var(--transition-base);
  }

  .project-card:hover {
    transform: translateY(-4px) scale(1.015);
    color: var(--color-text);
    text-decoration: none;
    font-weight: inherit;
  }

  .project-card:focus-visible {
    text-decoration: none;
    font-weight: inherit;
  }

  .project-card__frame {
    height: 100%;
  }

  .card-thumbnail {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
  }

  .card-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-sm);
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    margin: 0;
    justify-content: flex-end;
  }

  .card-description {
    margin: 0;
    font-size: var(--text-base);
    color: var(--color-navy);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-date {
    display: inline-block;
    flex-shrink: 0;
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    margin: 0;
  }

  @media (max-width: 640px) {
    .card-meta {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-xs);
    }

    .card-tags {
      justify-content: flex-start;
    }
  }
</style>
