---
import type { Lang } from "../i18n/ui";
import type { JsonLd } from "../seo/schema";
import {
  SAME_AS_LINKS,
  SITE_NAME,
  getDefaultRobots,
  toAbsoluteUrl,
} from "../seo/site";

interface Props {
  title: string;
  description?: string;
  lang: Lang;
  ogImage?: string;
  canonicalPath?: string;
  keywords?: string[];
  pageType?: "website" | "article";
  noindex?: boolean;
  publishedTime?: string;
  modifiedTime?: string;
  schema?: JsonLd[];
  alternates?: Partial<Record<Lang, string>> | false;
}

const {
  title,
  description,
  lang,
  ogImage,
  canonicalPath,
  keywords = [],
  pageType = "website",
  noindex = false,
  publishedTime,
  modifiedTime,
  schema = [],
  alternates,
} = Astro.props;
const siteUrl = Astro.site?.toString().replace(/\/$/, "") ?? "";
const currentPath = Astro.url.pathname;
const canonicalUrl = canonicalPath
  ? toAbsoluteUrl(canonicalPath)
  : siteUrl
    ? toAbsoluteUrl(currentPath)
    : Astro.url.href;

const alternateLang = lang === "en" ? "es" : "en";
const alternatePath =
  lang === "en" ? `/es${currentPath}` : currentPath.replace(/^\/es/, "") || "/";
const alternateUrls =
  alternates === false
    ? []
    : Object.entries(
        alternates ?? {
          [lang]: currentPath,
          [alternateLang]: alternatePath,
        },
      ).map(([locale, path]) => ({
        locale,
        href: toAbsoluteUrl(path ?? "/"),
      }));
const xDefaultHref =
  alternateUrls.find((entry) => entry.locale === "en")?.href ?? canonicalUrl;
const robotsContent = getDefaultRobots(noindex);
const resolvedOgImage = ogImage
  ? toAbsoluteUrl(ogImage)
  : toAbsoluteUrl("/images/projects/jv-portfolio.png");
---

<title>{title}</title>
{description && <meta name="description" content={description} />}
{keywords.length > 0 && <meta name="keywords" content={keywords.join(", ")} />}
<meta name="author" content="Jesús Villar" />
<meta name="creator" content="Jesús Villar" />
<meta name="publisher" content="Jesús Villar" />
<meta name="robots" content={robotsContent} />
<meta name="googlebot" content={robotsContent} />
<meta name="referrer" content="strict-origin-when-cross-origin" />
<meta name="theme-color" content="#FFF5D2" />

<!-- Canonical & Hreflang -->
<link rel="canonical" href={canonicalUrl} />
{
  alternateUrls.map((entry) => (
    <link rel="alternate" hreflang={entry.locale} href={entry.href} />
  ))
}
{
  alternateUrls.length > 0 && (
    <link rel="alternate" hreflang="x-default" href={xDefaultHref} />
  )
}
{SAME_AS_LINKS.map((href) => <link rel="me" href={href} />)}

<!-- Open Graph -->
<meta property="og:title" content={title} />
{description && <meta property="og:description" content={description} />}
<meta property="og:type" content={pageType} />
<meta property="og:site_name" content={SITE_NAME} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:locale" content={lang === "en" ? "en_US" : "es_ES"} />
<meta
  property="og:locale:alternate"
  content={lang === "en" ? "es_ES" : "en_US"}
/>
<meta property="og:image" content={resolvedOgImage} />
<meta property="og:image:alt" content={title} />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
{description && <meta name="twitter:description" content={description} />}
<meta name="twitter:image" content={resolvedOgImage} />

{
  pageType === "article" &&
    publishedTime && (
      <meta property="article:published_time" content={publishedTime} />
    )
}
{
  pageType === "article" &&
    modifiedTime && (
      <meta property="article:modified_time" content={modifiedTime} />
    )
}
{
  pageType === "article" &&
    keywords.map((keyword) => <meta property="article:tag" content={keyword} />)
}

{
  schema.map((node) => (
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(node)}
    />
  ))
}
